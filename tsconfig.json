{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@payflow/shared": ["./packages/shared/types"],
      "@payflow/sdk": ["./packages/payflow-sdk/src"],
      "@payflow/server": ["./packages/payflow-server/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
